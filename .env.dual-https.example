# Copy to .env when using docker-compose.https.yml
# This project will be reachable through both:
#   https://172.27.1.92
#   https://10.156.119.146

# Best for two IPs: QR stores only MACHINEQR:QR-XXXX.
# Users open the app through whichever network IP works, then scan inside Follow up.
QR_PAYLOAD_MODE=code

# Leave blank in QR_PAYLOAD_MODE=code.
# If you change QR_PAYLOAD_MODE=url, set ONE canonical URL only, e.g. https://172.27.1.92
PUBLIC_APP_URL=
