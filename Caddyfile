# HTTPS entrypoint.
# Caddy listens on port 443 for any IP/host on this machine.
# The certificate in certs/qr-system.crt MUST include the IP/host users open as a SAN.
# Examples for testing/factory:
#   IP:192.168.0.242
#   IP:172.27.1.92
#   IP:10.156.119.146
#   DNS:localhost

:443 {
    tls /certs/qr-system.crt /certs/qr-system.key
    encode gzip

    reverse_proxy qr-system:5057 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
        header_up Host {host}
    }
}

# Redirect plain HTTP to HTTPS when users type the IP without https://
:80 {
    redir https://{host}{uri} permanent
}
